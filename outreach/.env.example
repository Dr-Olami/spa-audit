# =========================================================================
# Twilio WhatsApp
# =========================================================================
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your production WhatsApp Business sender (must include "whatsapp:" prefix)
TWILIO_WHATSAPP_FROM=whatsapp:+14099083940

# Twilio's shared sandbox sender (use this for testing before templates are approved)
TWILIO_WHATSAPP_SANDBOX_FROM=whatsapp:+14155238886

# Flip to "false" when your production number + Meta-approved templates are live
TWILIO_USE_SANDBOX=true

# Content (template) SID for the cold-outreach icebreaker.
# Create in Twilio Console > Content Editor, get it Meta-approved, then paste here.
# Format: HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TEMPLATE_ICEBREAKER_SID=

# =========================================================================
# Google Places API (New) — preferred over scraping
# Enable at https://console.cloud.google.com/apis/library/places.googleapis.com
# =========================================================================
GOOGLE_PLACES_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =========================================================================
# Links used inside messages
# =========================================================================
LANDING_URL=https://your-domain.com
CAL_URL=https://cal.com/miracle-edeh/salon-audit

# =========================================================================
# Database & server
# =========================================================================
DATABASE_URL=sqlite:///./leads.db
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8000

# Twilio will sign webhook requests with this. Pull from Twilio console.
# Leave blank in local dev (signature validation is then skipped).
TWILIO_WEBHOOK_VALIDATE=false

# =========================================================================
# Admin dashboard (/admin) — sqladmin
# =========================================================================
# Comma-separated user:password pairs. Add one entry per teammate.
# Example: ADMIN_USERS=miracle:s3cret,abdul:other-s3cret
# If left blank, the admin is mounted WITHOUT authentication — only safe on localhost.
ADMIN_USERS=

# Random string used to sign session cookies. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_SESSION_SECRET=

# =========================================================================
# Cal.com webhook (/webhook/cal)
# =========================================================================
# Copy from Cal.com -> Settings -> Developer -> Webhooks -> your webhook -> Secret.
# When set, every incoming Cal webhook must carry a valid X-Cal-Signature-256
# header or it is rejected with 403. Leave blank ONLY for local dev.
CAL_WEBHOOK_SECRET=

# =========================================================================
# HTTP API (/api/jobs/*)
# =========================================================================
# Token required as `Authorization: Bearer <token>` on /api/* routes.
# Admin session cookies are accepted too, so the dashboard works without
# exposing this token in the browser. Leave blank to disable Bearer auth.
API_TOKEN=

# =========================================================================
# Background scheduler (APScheduler, in-process while `outreach serve` runs)
# =========================================================================
# Master switch. Set to "true" to enable daily cron jobs.
SCHEDULER_ENABLED=false

# Daily qualify pass (UTC). Re-enriches NEW leads.
DAILY_QUALIFY_HOUR=2
DAILY_QUALIFY_MINUTE=0
DAILY_QUALIFY_LIMIT=100

# Optional daily Google Places scrape. Comma-separated list of queries;
# leave blank to skip the daily scrape entirely.
# Example: "salon in Lekki, Lagos, spa in Victoria Island, Lagos"
DAILY_SCRAPE_QUERIES=
DAILY_SCRAPE_CITY=
DAILY_SCRAPE_MAX=20
DAILY_SCRAPE_HOUR=1
DAILY_SCRAPE_MINUTE=0
