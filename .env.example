# Public site URL (used in SEO metadata, sitemap, Open Graph)
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Your cal.com link in "username/event-slug" format (no domain, no leading slash)
# Full URL: https://cal.com/miracle-edeh/salon-audit  -> use only the part after cal.com/
NEXT_PUBLIC_CAL_LINK=miracle-edeh/salon-audit

# WhatsApp number in international format, no "+" or spaces
# Example: 2348012345678
NEXT_PUBLIC_WHATSAPP_NUMBER=2348012345678
